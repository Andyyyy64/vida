FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 alsa-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
COPY life/ life/
RUN pip install --no-cache-dir .

VOLUME /app/data

EXPOSE 3002

CMD ["life", "start"]
